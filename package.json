{
  "name": "cloudmusic",
  "productName": "cloudmusic",
  "version": "1.0.0",
  "description": "Electron app for NetEase Cloud Music",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "save": "rm -rf local-resources && SAVE_RESOURCES=true electron-forge start",
    "patch-local": "biome format --write --files-max-size=10485760 ./local-resources ; ts-node scripts/patch_settings.ts",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:linux-x64": "electron-forge make --arch=x64 --platform=linux",
    "make:linux-arm64": "electron-forge make --arch=arm64 --platform=linux"
  },
  "keywords": [],
  "author": {
    "name": "web1n",
    "email": "9633157+web1n@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "@reforged/maker-appimage": "^5.2.0",
    "electron": "^40.6.1",
    "mime": "^4.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {}
}
